# Provider selection
AGENT_PROVIDER=ollama          # ollama | openai | anthropic
AGENT_MODEL=                   # leave blank to use the per-provider default

# Ollama (cloud or local)
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Web search (optional — falls back to DuckDuckGo if unset)
TAVILY_API_KEY=

# Sub-models (vision + embeddings)
VISION_MODEL=qwen3-vl:235b-instruct
EMBED_MODEL=nomic-embed-text
EMBED_HOST=http://localhost:11434

# Telegram gateway (Phase 3)
TELEGRAM_BOT_TOKEN=              # from @BotFather
TELEGRAM_ALLOWED_USER_ID=        # your numeric Telegram user ID (from @userinfobot)

# Memory storage (default: ~/.synapse/)
SYNAPSE_HOME=

# Context window tuning
CONTEXT_WINDOW=128000
OUTPUT_RESERVE=16000
