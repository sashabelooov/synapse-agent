# Provider selection
AGENT_PROVIDER=ollama          # ollama | openai | anthropic
AGENT_MODEL=                   # leave blank to use the per-provider default

# Ollama (cloud or local)
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Web search (optional — falls back to DuckDuckGo if unset)
TAVILY_API_KEY=

# Sub-models (vision + embeddings)
VISION_MODEL=qwen3-vl:235b-instruct
EMBED_MODEL=nomic-embed-text
EMBED_HOST=http://localhost:11434

# Telegram gateway (Phase 3)
TELEGRAM_BOT_TOKEN=              # from @BotFather
TELEGRAM_ALLOWED_USER_ID=        # your numeric Telegram user ID (from @userinfobot)

# Memory storage (default: ~/.synapse/)
SYNAPSE_HOME=

# Context window tuning
CONTEXT_WINDOW=128000
OUTPUT_RESERVE=16000

# Cron scheduler — Phase 5
CRON_JOBS_PATH=                    # Path to cron_jobs.json (default: ~/.synapse/cron_jobs.json)

# Voice — Phase 4
# STT (speech-to-text)
WHISPER_BACKEND=openai             # openai (default) | local (requires Python 3.12+ and faster-whisper)
WHISPER_LOCAL_MODEL=base           # faster-whisper model size when WHISPER_BACKEND=local

# TTS (text-to-speech)
TTS_BACKEND=edge                   # edge (default, free) | openai | pyttsx3 (offline)
EDGE_TTS_VOICE=en-US-AriaNeural   # Microsoft neural voice (see: edge-tts --list-voices)
OPENAI_TTS_VOICE=alloy             # OpenAI voice when TTS_BACKEND=openai
TTS_OUTPUT_DIR=                    # Directory for generated audio files (default: system temp)

# Telegram voice replies
VOICE_REPLY=false                  # Set to true to send TTS voice replies after text replies

# Computer use — Phase 9
ALLOW_COMPUTER_USE=false           # Set to true to enable mouse/keyboard control (DANGEROUS)

# Image generation — Phase 10
IMAGE_BACKEND=openai               # openai (DALL-E 3, default) | diffusers (local SD)
IMAGE_MODEL=dall-e-3               # dall-e-3 | dall-e-2
IMAGE_OUTPUT_DIR=                  # Directory for generated images (default: system temp)
IMAGE_DIFFUSERS_MODEL=runwayml/stable-diffusion-v1-5   # HuggingFace model (diffusers backend)
IMAGE_DEVICE=                      # cuda | cpu (diffusers backend; auto-detected if blank)

# Video generation — Phase 10
VIDEO_BACKEND=replicate            # replicate (default) | runway
REPLICATE_API_TOKEN=               # From replicate.com/account/api-tokens
VIDEO_REPLICATE_MODEL=minimax/video-01-live   # Any Replicate video model ID
RUNWAY_API_KEY=                    # From app.runwayml.com/settings
VIDEO_OUTPUT_DIR=                  # Directory for generated videos (default: system temp)

# MCP servers — Phase 12 (all optional; server is skipped with a warning if blank)

# Context7 — live library docs (no credentials needed, just requires npx / Node.js)

# PostgreSQL MCP — read-only SQL queries on your own databases
POSTGRES_CONNECTION_STRING=        # e.g. postgresql://user:pass@localhost:5432/mydb

# Filesystem MCP — give the agent controlled access to specific local directories
FILESYSTEM_ALLOWED_DIRS=           # Space-separated absolute paths, e.g. /home/user/projects

# Slack MCP — read Slack channels and messages
SLACK_BOT_TOKEN=                   # Bot token from api.slack.com/apps
SLACK_TEAM_ID=                     # T... workspace ID (Settings → About This Workspace)
